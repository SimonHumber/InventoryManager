@model IEnumerable<Inventory.Shared.Dtos.CategoryDto>
@{
    ViewData["Title"] = "Categories";
    var search = ViewBag.Search as string;
}

<div class="page-header">
    <div>
        <h1>Categories</h1>
        <p class="page-subtitle">Group products by type</p>
    </div>
    @if (User.IsInRole(IdentitySeeder.AdminRole))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New category</a>
    }
</div>

<form class="filter-toolbar" method="get">
    <div class="row g-2 align-items-end">
        <div class="col-md-6 col-lg-4">
            <label class="form-label small text-muted">Search</label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@search" class="form-control" placeholder="Name or description" />
            </div>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" type="submit"><i class="bi bi-funnel"></i> Filter</button>
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <a asp-action="Index" class="btn btn-outline-secondary ms-1">Reset</a>
            }
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-tags"></i>
                <p class="mb-0">No categories found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th class="text-end">Products</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@c.Name</td>
                                <td class="text-muted">@c.Description</td>
                                <td class="text-end"><span class="badge-soft">@c.ProductCount</span></td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                                    @if (User.IsInRole(IdentitySeeder.AdminRole))
                                    {
                                        <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
