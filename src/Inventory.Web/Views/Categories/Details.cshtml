@model Inventory.Shared.Dtos.CategoryDto
@{
    ViewData["Title"] = "Category details";
}

<div class="page-header">
    <h1>@Model.Name</h1>
    <div>
        @if (User.IsInRole(IdentitySeeder.AdminRole))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3 text-muted">Description</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</dd>
            <dt class="col-sm-3 text-muted">Products</dt>
            <dd class="col-sm-9"><span class="badge-soft">@Model.ProductCount</span></dd>
        </dl>
    </div>
</div>
