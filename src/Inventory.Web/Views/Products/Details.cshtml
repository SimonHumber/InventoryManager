@model Inventory.Shared.Dtos.ProductDto
@{
    ViewData["Title"] = "Product details";
    var low = Model.QuantityInStock <= Model.ReorderLevel;
}

<div class="page-header">
    <div>
        <h1>@Model.Name</h1>
        <p class="page-subtitle mb-0"><code>@Model.Sku</code></p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Stock" asp-action="Create" asp-route-productId="@Model.Id" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left-right"></i> Movement
        </a>
        @if (User.IsInRole(IdentitySeeder.AdminRole))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Description</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</dd>
                    <dt class="col-sm-4 text-muted">Category</dt>
                    <dd class="col-sm-8"><span class="badge-soft">@Model.CategoryName</span></dd>
                    <dt class="col-sm-4 text-muted">Supplier</dt>
                    <dd class="col-sm-8">@Model.SupplierName</dd>
                    <dt class="col-sm-4 text-muted">Created</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body text-center">
                <p class="stat-label mb-1">Unit price</p>
                <p class="stat-value">@Model.UnitPrice.ToString("C")</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <p class="stat-label mb-1">In stock</p>
                <p class="stat-value @(low ? "text-danger" : "")">@Model.QuantityInStock</p>
                <p class="small text-muted mb-0">Reorder at @Model.ReorderLevel</p>
            </div>
        </div>
    </div>
</div>
