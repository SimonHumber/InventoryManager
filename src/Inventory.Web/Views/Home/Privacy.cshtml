@{
    ViewData["Title"] = "Privacy";
}
<div class="page-header">
    <h1>Privacy</h1>
</div>
<div class="card">
    <div class="card-body">
        <p>
            This demo application stores the minimum data required to operate its
            Inventory Management features. User accounts (email, hashed password,
            and role assignments) are persisted in a local SQLite database used
            by ASP.NET Core Identity.
        </p>
        <p>
            Inventory data (products, categories, suppliers, stock movements)
            is stored in a second SQLite database managed by the Inventory
            Web API microservice.
        </p>
        <p class="mb-0 text-muted small">
            This is an educational project and is not intended for production use.
        </p>
    </div>
</div>
