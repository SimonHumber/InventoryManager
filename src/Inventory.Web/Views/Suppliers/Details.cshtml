@model Inventory.Shared.Dtos.SupplierDto
@{
    ViewData["Title"] = "Supplier details";
}

<div class="page-header">
    <h1>@Model.Name</h1>
    <div>
        @if (User.IsInRole(IdentitySeeder.AdminRole))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">Contact</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.ContactName) ? "—" : Model.ContactName)</dd>
            <dt class="col-sm-3 text-muted">Email</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Email) ? "—" : Model.Email)</dd>
            <dt class="col-sm-3 text-muted">Phone</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Phone) ? "—" : Model.Phone)</dd>
            <dt class="col-sm-3 text-muted">Address</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Address) ? "—" : Model.Address)</dd>
        </dl>
    </div>
</div>
